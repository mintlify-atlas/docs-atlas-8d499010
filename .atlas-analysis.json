  "keyFeatures": [
    "Seamless Cloudinary integration with Payload CMS",
    "Advanced versioning support with history tracking",
    "Customizable public ID generation",
    "Support for custom fields in media collections",
    "PDF support with thumbnail generation",
    "Dynamic folder mode support for newer Cloudinary accounts",
    "Automatic file deletion from Cloudinary",
    "URL generation with transformations"
